{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan2agent.local/schemas/spec.schema.json",
  "title": "Plan2Agent Product and Implementation Spec",
  "type": "object",
  "required": [
    "schema_version",
    "project_id",
    "source_intake",
    "product",
    "implementation",
    "clarifying_question_disposition",
    "open_decisions",
    "approval",
    "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "p2a.spec.v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "source_intake": {
      "type": "string",
      "minLength": 1
    },
    "product": {
      "type": "object",
      "required": [
        "problem",
        "target_users",
        "goals",
        "non_goals",
        "core_flows",
        "screens_or_interfaces",
        "data_model_draft",
        "external_integrations",
        "success_criteria",
        "constraints"
      ],
      "additionalProperties": false,
      "properties": {
        "problem": {
          "type": "string",
          "minLength": 1
        },
        "target_users": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "core_flows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "screens_or_interfaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "data_model_draft": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "external_integrations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "implementation": {
      "type": "object",
      "required": [
        "architecture",
        "interfaces",
        "data_flow",
        "dependencies",
        "edge_cases",
        "verification"
      ],
      "additionalProperties": false,
      "properties": {
        "architecture": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "interfaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "data_flow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "edge_cases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ND-[0-9]+$"
      }
    },
    "clarifying_question_disposition": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "rationale",
          "affects"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CQ-[0-9]+$"
          },
          "status": {
            "type": "string",
            "enum": [
              "answered",
              "assumed",
              "deferred_non_goal",
              "promoted_to_decision"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "affects": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "resolved_by": {
            "type": "string",
            "minLength": 1
          },
          "assumption": {
            "type": "string",
            "minLength": 1
          },
          "non_goal": {
            "type": "string",
            "minLength": 1
          },
          "promoted_decision_id": {
            "type": "string",
            "pattern": "^ND-[0-9]+$"
          },
          "resolution": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "approval": {
      "type": "string",
      "enum": [
        "draft",
        "approved"
      ]
    },
    "approval_audit": {
      "type": "object",
      "required": [
        "approved_by",
        "approved_at",
        "approved_artifacts",
        "approval_note"
      ],
      "additionalProperties": false,
      "properties": {
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "approved_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}"
        },
        "approved_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "approval_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reference_reconnaissance": {
      "type": "object",
      "required": [
        "triggers",
        "candidates",
        "selected_patterns",
        "rejected_patterns",
        "open_questions"
      ],
      "additionalProperties": false,
      "properties": {
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "candidate_id",
              "title",
              "source_id",
              "source_type",
              "summary",
              "used_for",
              "decision",
              "rationale"
            ],
            "additionalProperties": false,
            "properties": {
              "candidate_id": {
                "type": "string",
                "pattern": "^REF-[0-9]+$"
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "source_id": {
                "type": "string",
                "pattern": "^(WEB|USER|LOCAL)-[0-9]+$"
              },
              "source_type": {
                "type": "string",
                "enum": [
                  "official_doc",
                  "release_notes",
                  "standard",
                  "package_registry",
                  "source_repo",
                  "vendor_doc",
                  "local_code",
                  "local_artifact",
                  "user_input",
                  "other"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "used_for": {
                "type": "string",
                "minLength": 1
              },
              "decision": {
                "type": "string",
                "enum": [
                  "selected",
                  "rejected",
                  "context",
                  "open"
                ]
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "selected_patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "candidate_id",
              "pattern",
              "applies_to",
              "rationale"
            ],
            "additionalProperties": false,
            "properties": {
              "candidate_id": {
                "type": "string",
                "pattern": "^REF-[0-9]+$"
              },
              "pattern": {
                "type": "string",
                "minLength": 1
              },
              "applies_to": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "rejected_patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "candidate_id",
              "pattern",
              "rationale"
            ],
            "additionalProperties": false,
            "properties": {
              "candidate_id": {
                "type": "string",
                "pattern": "^REF-[0-9]+$"
              },
              "pattern": {
                "type": "string",
                "minLength": 1
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "title",
          "url",
          "used_for"
        ],
        "additionalProperties": false,
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^(WEB|USER|LOCAL)-[0-9]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string"
          },
          "used_for": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
