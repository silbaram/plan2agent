{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan2agent.local/schemas/skill-proposal.schema.json",
  "title": "Plan2Agent Skill Proposal",
  "type": "object",
  "required": [
    "schema_version",
    "proposalId",
    "problem",
    "recommendedChange",
    "targetFiles",
    "risk",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "p2a.skill_proposal.v1"
    },
    "proposalId": {
      "type": "string",
      "minLength": 1
    },
    "sourceRunId": {
      "type": ["string", "null"]
    },
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendedChange": {
      "type": "string",
      "minLength": 1
    },
    "targetFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "riskRationale": {
      "type": "string",
      "minLength": 1
    },
    "quality": {
      "type": "object",
      "required": [
        "score",
        "band",
        "criteria",
        "missing"
      ],
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "band": {
          "type": "string",
          "enum": ["strong", "medium", "weak"]
        },
        "criteria": {
          "type": "object",
          "required": [
            "evidence",
            "reproduction",
            "impactScope",
            "validation",
            "riskExplanation"
          ],
          "additionalProperties": false,
          "properties": {
            "evidence": {
              "type": "object",
              "required": ["passed", "detail"],
              "additionalProperties": false,
              "properties": {
                "passed": {"type": "boolean"},
                "detail": {"type": "string", "minLength": 1}
              }
            },
            "reproduction": {
              "type": "object",
              "required": ["passed", "detail"],
              "additionalProperties": false,
              "properties": {
                "passed": {"type": "boolean"},
                "detail": {"type": "string", "minLength": 1}
              }
            },
            "impactScope": {
              "type": "object",
              "required": ["passed", "detail"],
              "additionalProperties": false,
              "properties": {
                "passed": {"type": "boolean"},
                "detail": {"type": "string", "minLength": 1}
              }
            },
            "validation": {
              "type": "object",
              "required": ["passed", "detail"],
              "additionalProperties": false,
              "properties": {
                "passed": {"type": "boolean"},
                "detail": {"type": "string", "minLength": 1}
              }
            },
            "riskExplanation": {
              "type": "object",
              "required": ["passed", "detail"],
              "additionalProperties": false,
              "properties": {
                "passed": {"type": "boolean"},
                "detail": {"type": "string", "minLength": 1}
              }
            }
          }
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["evidence", "reproduction", "impactScope", "validation", "riskExplanation"]
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "approved", "rejected", "deferred"],
      "default": "proposed"
    },
    "note": {
      "type": "string"
    }
  }
}
