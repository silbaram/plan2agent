{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan2agent.local/schemas/milestone-review.schema.json",
  "title": "Plan2Agent Milestone Review",
  "type": "object",
  "required": [
    "schema_version",
    "project_id",
    "iteration_id",
    "checkpoint",
    "generated_at",
    "source",
    "confirmed_findings",
    "planned_todo_not_findings",
    "note"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "p2a.milestone_review.v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "iteration_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "checkpoint": {
      "type": "string",
      "enum": ["midpoint", "pre_close"]
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "task_graph_ref",
        "task_graph_sha256",
        "task_graph_snapshot",
        "task_graph_snapshot_sha256",
        "spec_ref",
        "style_ref",
        "task_counts",
        "task_snapshot",
        "completed_task_evidence",
        "remaining_task_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "task_graph_ref": {
          "type": "string",
          "minLength": 1
        },
        "task_graph_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "task_graph_snapshot": {
          "type": "object"
        },
        "task_graph_snapshot_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "spec_ref": {
          "type": "string",
          "minLength": 1
        },
        "style_ref": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "task_counts": {
          "type": "object",
          "required": ["total", "done", "todo", "in_progress", "blocked"],
          "additionalProperties": false,
          "properties": {
            "total": { "type": "integer", "minimum": 1 },
            "done": { "type": "integer", "minimum": 0 },
            "todo": { "type": "integer", "minimum": 0 },
            "in_progress": { "type": "integer", "minimum": 0 },
            "blocked": { "type": "integer", "minimum": 0 }
          }
        },
        "task_snapshot": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["task_id", "task_title", "status"],
            "additionalProperties": false,
            "properties": {
              "task_id": {
                "type": "string",
                "pattern": "^task-[0-9]+$"
              },
              "task_title": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": ["todo", "in_progress", "done", "blocked"]
              }
            }
          }
        },
        "completed_task_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "task_id",
              "task_title",
              "run_id",
              "run_ref",
              "run_sha256",
              "run_snapshot",
              "run_snapshot_sha256",
              "run_finished_at",
              "changed_files",
              "verification"
            ],
            "additionalProperties": false,
            "properties": {
              "task_id": {
                "type": "string",
                "pattern": "^task-[0-9]+$"
              },
              "task_title": {
                "type": "string",
                "minLength": 1
              },
              "run_id": {
                "type": "string",
                "pattern": "^run-[A-Za-z0-9._-]+$"
              },
              "run_ref": {
                "type": "string",
                "pattern": "^runs/run-[A-Za-z0-9._-]+\\.json$"
              },
              "run_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "run_snapshot": {
                "type": "object"
              },
              "run_snapshot_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "run_finished_at": {
                "type": "string",
                "minLength": 1
              },
              "changed_files": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "verification": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["type", "command", "status", "exit_code", "source"],
                  "additionalProperties": false,
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["test", "lint", "typecheck", "custom"]
                    },
                    "command": {
                      "type": "string",
                      "minLength": 1
                    },
                    "status": {
                      "type": "string",
                      "enum": ["passed", "failed", "skipped", "not_run", "unavailable"]
                    },
                    "exit_code": {
                      "type": ["integer", "null"]
                    },
                    "source": {
                      "type": "string",
                      "enum": ["config", "command", "manual"]
                    }
                  }
                }
              }
            }
          }
        },
        "remaining_task_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^task-[0-9]+$"
          }
        }
      }
    },
    "confirmed_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "category",
          "severity",
          "summary",
          "evidence",
          "affected_completed_tasks",
          "maintenance_recommendation"
        ],
        "additionalProperties": false,
        "properties": {
          "finding_id": {
            "type": "string",
            "pattern": "^MRF-[A-Za-z0-9._-]+$"
          },
          "category": {
            "type": "string",
            "enum": ["integration", "api", "data", "concurrency", "security", "error_handling", "tests", "other"]
          },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kind", "reference", "detail"],
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["file", "task", "run", "verification", "spec"]
                },
                "reference": {
                  "type": "string",
                  "minLength": 1
                },
                "detail": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "affected_completed_tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^task-[0-9]+$"
            }
          },
          "maintenance_recommendation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "planned_todo_not_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["summary", "covered_by_remaining_tasks", "evidence"],
        "additionalProperties": false,
        "properties": {
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "covered_by_remaining_tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^task-[0-9]+$"
            }
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kind", "reference", "detail"],
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["task", "spec"]
                },
                "reference": {
                  "type": "string",
                  "minLength": 1
                },
                "detail": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "note": {
      "type": "string"
    }
  }
}
