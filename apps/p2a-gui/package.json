{
  "name": "@plan2agent/p2a-gui",
  "version": "0.1.0",
  "private": true,
  "description": "Plan2Agent supervised desktop GUI",
  "main": ".vite/build/main.js",
  "scripts": {
    "postinstall": "node scripts/ensure-node-pty-helper-mode.mjs",
    "prepackage": "node scripts/ensure-node-pty-helper-mode.mjs",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "package:mac": "electron-forge package --platform=darwin --arch=arm64",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "npm run package"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "ajv": "8.20.0",
    "lucide-react": "1.21.0",
    "node-pty": "1.1.0",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "electron": "42.4.1",
    "playwright": "1.61.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "overrides": {
    "@electron/rebuild": "4.0.4",
    "tmp": "0.2.7"
  }
}
